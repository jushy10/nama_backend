# Copy to .env (gitignored) and adjust. The app reads DATABASE_URL at startup;
# if it's unset, it falls back to a local SQLite file (sqlite:///./nama.db).

# --- Local SQLite (default) -------------------------------------------------
# DATABASE_URL=sqlite:///./nama.db

# --- PostgreSQL on Amazon RDS -----------------------------------------------
# Use the +psycopg driver and require TLS. `verify-full` checks the server's
# certificate against the RDS CA bundle (download global-bundle.pem from AWS and
# point sslrootcert at it).
#
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@your-db.xxxx.us-east-1.rds.amazonaws.com:5432/nama?sslmode=verify-full&sslrootcert=/etc/ssl/certs/rds-ca.pem
#
# In production, don't hardcode the password here — inject it from AWS Secrets
# Manager (see infra/README.md).
