# Copy to terraform.tfvars and fill in your values, then `terraform apply`.
# terraform.tfvars is gitignored — never commit real IDs if they're sensitive.

region      = "us-east-1"
project     = "nama"
environment = "prod"

# Your VPC and PRIVATE subnets (at least two, in different AZs).
vpc_id        = "vpc-0123456789abcdef0"
db_subnet_ids = ["subnet-aaaa1111", "subnet-bbbb2222"]

# Security group(s) attached to your app (ECS/EC2/Lambda). Only these can reach
# the DB. Leave empty for now and add it once the app's SG exists.
allowed_app_security_group_ids = ["sg-0app1111app2222a"]

# Optional overrides:
# instance_class = "db.t4g.micro"
# multi_az       = false
